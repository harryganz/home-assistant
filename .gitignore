# Host-specific env values
.env

# Home Assistant runtime state / secrets — never commit these
homeassistant/config/secrets.yaml
homeassistant/config/.storage/
homeassistant/config/.cloud/
homeassistant/config/*.db
homeassistant/config/*.db-*
homeassistant/config/*.log
homeassistant/config/*.log.*
homeassistant/config/tts/
homeassistant/config/deps/
homeassistant/config/image/
homeassistant/config/blueprints/
homeassistant/config/.HA_VERSION
homeassistant/config/.ha_run.lock
homeassistant/config/.cache/
homeassistant/config/.shopping_list.json

# Wyoming Whisper model cache — large binaries, redownloaded per instance
whisper/data/

# Wyoming Piper voice model cache — large binaries, redownloaded per instance
piper/data/

# Claude Code local settings
.claude/settings.local.json
