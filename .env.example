# Copy this file to .env and fill in values for this host.
# .env is gitignored — it's host-specific and never committed.

# IANA timezone, e.g. America/New_York, Europe/London
TZ=UTC

# Path to the Home Assistant config directory (bind-mounted as /config)
HA_CONFIG_DIR=./homeassistant/config

# Wyoming Whisper (local speech-to-text, used by HA's Assist pipeline)
# Model size: tiny/base/small/medium/large-v3, optionally with .en for
# English-only (more accurate for English than multilingual at the same
# size). WHISPER_COMPUTE_TYPE=int8 quantizes for faster/lighter inference
# at a small accuracy cost; use "default" to let it pick per-device.
# tiny/base + int8 are reasonable for modest CPUs; medium.en needs decent
# CPU/GPU hardware.
WHISPER_MODEL=medium.en
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=en
WHISPER_DATA_DIR=./whisper/data

# Wyoming Piper (local text-to-speech, used by HA's Assist pipeline)
# Voice name, e.g. en_US-lessac-medium — see https://github.com/rhasspy/piper/blob/master/VOICES.md
PIPER_VOICE=en_US-joe-medium
PIPER_DATA_DIR=./piper/data
